// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?   // Only set for email/password accounts
  accounts      Account[]
  sessions      Session[]
  
  // App Specific
  tasks         Task[]
  routines      Routine[]
  projects      Project[]
  sharedProjects Project[] @relation("ProjectCollaborators")

  // Admin & Billing
  role             String    @default("USER") // USER, ADMIN
  status           String    @default("ACTIVE") // ACTIVE, SUSPENDED, BLOCKED
  plan             String    @default("FREE") // FREE, PRO, PREMIUM
  stripeCustomerId String?
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Project {
  id          String   @id @default(cuid())
  name        String
  color       String
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  collaborators User[] @relation("ProjectCollaborators")
  tasks       Task[]
  createdAt   DateTime @default(now())
}

model Routine {
  id          String   @id @default(cuid())
  name        String
  timeSlot    String
  color       String
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model Task {
  id          String   @id @default(cuid())
  title       String
  isDone      Boolean  @default(false)
  priority    String   @default("low") // high, medium, low
  date        DateTime?
  time        String?
  routineName String?
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
