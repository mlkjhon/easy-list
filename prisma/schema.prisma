// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?   // Only set for email/password accounts
  accounts      Account[]
  sessions      Session[]
  
  // App Specific
  tasks         Task[]
  routines      Routine[]
  shoppingLists ShoppingList[]

  // Teams
  teamMembers    TeamMember[]
  teamMessages   TeamMessage[]
  invitationsReceived TeamInvitation[] @relation("InvitedUser")

  // Admin & Billing
  role             String    @default("USER") // USER, ADMIN
  status           String    @default("ACTIVE") // ACTIVE, SUSPENDED, BLOCKED
  plan             String    @default("FREE") // FREE, PRO, PREMIUM
  stripeCustomerId String?
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Routine {
  id          String   @id @default(cuid())
  name        String
  timeSlot    String
  color       String
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model Task {
  id           String   @id @default(cuid())
  title        String
  description  String?  // Free-text description
  topics       String[] @default([]) // Key points / bullet points
  isDone       Boolean  @default(false)
  priority     String   @default("low") // high, medium, low
  date         DateTime?
  time         String?
  startTime    String?  // HH:MM format
  endTime      String?  // HH:MM format
  routineName  String?
  teamId       String?
  team         Team?    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  assignedToId String?  // userId of the team member this task is assigned to
  assignedById String?  // userId of who assigned this task
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ShoppingList {
  id        String         @id @default(cuid())
  name      String
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     ShoppingItem[]
  createdAt DateTime       @default(now())
}

model ShoppingItem {
  id             String       @id @default(cuid())
  name           String
  quantity       Float        @default(1)
  unit           String       @default("un") // un, kg, L, g, ml, cx, pct
  category       String       @default("Outros") // Hortifruti, Mercearia, Limpeza, Higiene, Bebidas, Outros
  estimatedPrice Float?
  isPurchased    Boolean      @default(false)
  listId         String
  list           ShoppingList @relation(fields: [listId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
}

model Team {
  id          String   @id @default(cuid())
  name        String
  description String?
  color       String   @default("#3D7A5E")
  ownerId     String   // ID of the Anfitrião (owner)
  createdAt   DateTime @default(now())
  
  members     TeamMember[]
  messages    TeamMessage[]
  tasks       Task[]
  invitations TeamInvitation[]
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  userId    String
  // Roles: OWNER | VICE_OWNER | SUPERVISOR | WORKER
  role      String   @default("WORKER")
  joinedAt  DateTime @default(now())
  
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model TeamInvitation {
  id        String   @id @default(cuid())
  teamId    String
  email     String
  invitedUserId String?  // Filled when a registered user matches the email
  role      String   @default("WORKER") // VICE_OWNER | SUPERVISOR | WORKER
  status    String   @default("PENDING") // PENDING | ACCEPTED | DECLINED
  createdAt DateTime @default(now())
  
  team         Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  invitedUser  User? @relation("InvitedUser", fields: [invitedUserId], references: [id], onDelete: SetNull)

  @@unique([teamId, email])
}

model TeamMessage {
  id        String   @id @default(cuid())
  content   String
  teamId    String
  userId    String
  createdAt DateTime @default(now())
  
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
